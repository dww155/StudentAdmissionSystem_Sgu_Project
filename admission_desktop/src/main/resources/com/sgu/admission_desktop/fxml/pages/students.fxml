<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sgu.admission_desktop.controller.StudentsPageController"
      styleClass="page" spacing="14.0">
    <VBox styleClass="card" spacing="12.0">
        <HBox spacing="10.0" styleClass="toolbar">
            <TextField fx:id="searchField" promptText="Tìm theo CCCD, họ tên..." HBox.hgrow="ALWAYS"/>
            <Button text="Tìm kiếm" onAction="#onSearch" styleClass="btn-primary"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Import" styleClass="btn-success"/>
            <Button text="Thêm mới" onAction="#onAddNew" styleClass="btn-primary"/>
        </HBox>

        <TableView fx:id="table" styleClass="table">
            <columns>
                <TableColumn fx:id="colMaTs" text="Mã TS"/>
                <TableColumn fx:id="colHoTen" text="Họ và tên"/>
                <TableColumn fx:id="colCccd" text="CCCD"/>
                <TableColumn fx:id="colNgaySinh" text="Ngày sinh"/>
                <TableColumn fx:id="colEmail" text="Email"/>
                <TableColumn fx:id="colSdt" text="SĐT"/>
            </columns>
        </TableView>

        <Label text="Ví dụ dữ liệu mẫu (demo)" styleClass="muted"/>
    </VBox>
</VBox>

