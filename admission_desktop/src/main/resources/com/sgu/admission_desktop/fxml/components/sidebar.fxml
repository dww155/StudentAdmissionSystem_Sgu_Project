<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sgu.admission_desktop.controller.SidebarController"
      prefWidth="260.0" styleClass="sidebar">
    <VBox styleClass="sidebar-header">
        <Label text="HỆ THỐNG TUYỂN SINH" styleClass="sidebar-title"/>
        <Label text="Trường Đại Học Sài Gòn" styleClass="sidebar-subtitle"/>
    </VBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
        <content>
            <VBox fx:id="navBox" spacing="4.0" styleClass="sidebar-nav">
                <padding>
                    <Insets top="0.0" right="0.0" bottom="12.0" left="0.0"/>
                </padding>

                <Label text="Menu chính" styleClass="sidebar-section"/>

                <Button text="Tổng quan" onAction="#onNav" userData="dashboard" styleClass="sidebar-item"/>
                <Button text="Quản lý thí sinh" onAction="#onNav" userData="students" styleClass="sidebar-item"/>
                <Button text="Ngành tuyển sinh" onAction="#onNav" userData="majors" styleClass="sidebar-item"/>
                <Button text="Tổ hợp môn" onAction="#onNav" userData="subjects" styleClass="sidebar-item"/>
                <Button text="Ngành - Tổ hợp" onAction="#onNav" userData="major-subjects" styleClass="sidebar-item"/>
                <Button text="Điểm thí sinh" onAction="#onNav" userData="scores" styleClass="sidebar-item"/>
                <Button text="Điểm cộng" onAction="#onNav" userData="bonus" styleClass="sidebar-item"/>
                <Button text="Nguyện vọng" onAction="#onNav" userData="wishes" styleClass="sidebar-item"/>
                <Button text="Bảng quy đổi" onAction="#onNav" userData="conversion" styleClass="sidebar-item"/>
            </VBox>
        </content>
    </ScrollPane>

    <VBox styleClass="sidebar-footer">
        <Separator opacity="0.20"/>
        <HBox spacing="10.0" styleClass="sidebar-user">
            <StackPane prefHeight="36.0" prefWidth="36.0" styleClass="avatar">
                <Label text="AD" styleClass="avatar-text"/>
            </StackPane>
            <VBox>
                <Label text="Admin" styleClass="sidebar-user-name"/>
                <Label text="Quản trị viên" styleClass="sidebar-user-role"/>
            </VBox>
        </HBox>
        <Button text="Đổi mật khẩu" onAction="#onChangePassword" styleClass="sidebar-footer-btn"/>
    </VBox>
</VBox>

