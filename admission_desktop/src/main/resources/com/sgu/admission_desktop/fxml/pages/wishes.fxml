<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgu.admission_desktop.controller.WishesPageController"
      styleClass="page" spacing="14.0">
    <VBox styleClass="card" spacing="12.0">
        <HBox styleClass="toolbar" spacing="10.0">
            <Label text="Quản lý nguyện vọng và xét tuyển" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Import" onAction="#onImport" styleClass="btn-success"/>
            <Button text="Thêm mới" onAction="#onAddNew" styleClass="btn-primary"/>
        </HBox>
        <TableView fx:id="table" styleClass="table">
            <columns>
                <TableColumn fx:id="colMaTs" text="Mã TS"/>
                <TableColumn fx:id="colHoTen" text="Họ tên"/>
                <TableColumn fx:id="colNguyenVong" text="Nguyện vọng"/>
                <TableColumn fx:id="colTenNganh" text="Ngành"/>
                <TableColumn fx:id="colMaToHop" text="Tổ hợp"/>
                <TableColumn fx:id="colTongDiem" text="Tổng điểm"/>
                <TableColumn fx:id="colTrangThai" text="Trạng thái"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
