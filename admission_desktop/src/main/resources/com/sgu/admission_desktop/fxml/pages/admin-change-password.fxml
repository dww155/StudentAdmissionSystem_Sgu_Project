<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgu.admission_desktop.controller.AdminChangePasswordController"
      styleClass="page" spacing="14.0">

    <VBox styleClass="card" spacing="12.0">
        <Label text="Đổi mật khẩu cho quản trị viên" styleClass="card-title"/>

        <GridPane hgap="12" vgap="10">
            <Label text="Mật khẩu hiện tại" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <PasswordField fx:id="currentPasswordField"
                            promptText="Nhập mật khẩu hiện tại"
                            styleClass="text-field"
                            GridPane.rowIndex="0"
                            GridPane.columnIndex="1"/>

            <Label text="Mật khẩu mới" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <PasswordField fx:id="newPasswordField"
                            promptText="Ít nhất 6 ký tự"
                            styleClass="text-field"
                            GridPane.rowIndex="1"
                            GridPane.columnIndex="1"/>

            <Label text="Nhập lại mật khẩu mới" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="confirmPasswordField"
                            promptText="Nhập lại mật khẩu mới"
                            styleClass="text-field"
                            GridPane.rowIndex="2"
                            GridPane.columnIndex="1"/>
        </GridPane>

        <Label fx:id="statusLabel" styleClass="muted"/>

        <HBox spacing="10.0" styleClass="toolbar">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Hủy" onAction="#onCancel" styleClass="btn-success"/>
            <Button fx:id="updateButton" text="Cập nhật" onAction="#onUpdate" styleClass="btn-primary"/>
        </HBox>
    </VBox>
</VBox>

