<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgu.admission_desktop.controller.ConversionPageController"
      styleClass="page" spacing="14.0">
    <VBox styleClass="card" spacing="12.0">
        <HBox styleClass="toolbar" spacing="10.0">
            <Label text="Bảng quy đổi điểm" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField promptText="Tìm kiếm..." prefWidth="220.0"/>
            <Button text="Import" onAction="#onImport" styleClass="btn-success"/>
            <Button text="Thêm mới" onAction="#onAddNew" styleClass="btn-primary"/>
        </HBox>
        <TableView fx:id="table" styleClass="table">
            <columns>
                <TableColumn fx:id="colLoaiDiem" text="Loại điểm"/>
                <TableColumn fx:id="colDiemGoc" text="Điểm gốc"/>
                <TableColumn fx:id="colDiemQuyDoi" text="Điểm quy đổi"/>
                <TableColumn fx:id="colHeSo" text="Hệ số"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
