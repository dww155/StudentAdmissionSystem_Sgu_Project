<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgu.admission_desktop.controller.MajorsPageController"
      styleClass="page" spacing="14.0">
    <VBox styleClass="card" spacing="12.0">
        <HBox styleClass="toolbar" spacing="10.0">
            <Label text="Danh sách ngành tuyển sinh" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Import" styleClass="btn-success"/>
            <Button text="Thêm mới" onAction="#onAddNew" styleClass="btn-primary"/>
        </HBox>
        <TableView fx:id="table" styleClass="table">
            <columns>
                <TableColumn fx:id="colMaNganh" text="Mã ngành"/>
                <TableColumn fx:id="colTenNganh" text="Tên ngành"/>
                <TableColumn fx:id="colChiTieu" text="Chỉ tiêu"/>
            </columns>
        </TableView>
    </VBox>
</VBox>

