<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgu.admission_desktop.controller.BonusPageController"
      styleClass="page" spacing="14.0">
    <VBox styleClass="card" spacing="12.0">
        <HBox styleClass="toolbar" spacing="10.0">
            <Label text="Quản lý điểm cộng" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Import" styleClass="btn-success"/>
            <Button text="Thêm mới" onAction="#onAddNew" styleClass="btn-primary"/>
        </HBox>
        <TableView fx:id="table" styleClass="table">
            <columns>
                <TableColumn fx:id="colMaTs" text="Mã TS"/>
                <TableColumn fx:id="colHoTen" text="Họ tên"/>
                <TableColumn fx:id="colDiemCong" text="Điểm cộng"/>
                <TableColumn fx:id="colLyDo" text="Lý do"/>
            </columns>
        </TableView>
    </VBox>
</VBox>

