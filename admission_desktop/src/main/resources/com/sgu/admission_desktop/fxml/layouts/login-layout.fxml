<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sgu.admission_desktop.controller.LoginController"
           styleClass="login-root">
    <VBox styleClass="card login-card" spacing="12.0" maxWidth="420.0">
        <padding>
            <Insets top="22.0" right="22.0" bottom="22.0" left="22.0" />
        </padding>

        <Label text="SGU Admission Desktop" styleClass="page-title" />
        <Label text="Sign in to continue" styleClass="muted" />

        <TextField fx:id="usernameField"
                   promptText="Username"
                   onAction="#onLogin" />

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       onAction="#onLogin" />

        <Label fx:id="errorLabel"
               styleClass="login-error"
               wrapText="true"
               visible="false"
               managed="false" />

        <Region VBox.vgrow="ALWAYS" />

        <Button fx:id="loginButton"
                text="Login"
                maxWidth="Infinity"
                onAction="#onLogin"
                styleClass="btn-primary" />
    </VBox>
</StackPane>
