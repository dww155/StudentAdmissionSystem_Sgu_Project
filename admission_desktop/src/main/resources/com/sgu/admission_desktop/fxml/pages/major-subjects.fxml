<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgu.admission_desktop.controller.MajorSubjectsPageController"
      styleClass="page" spacing="14.0">
    <VBox styleClass="card" spacing="12.0">
        <HBox styleClass="toolbar" spacing="10.0">
            <Label text="Lien ket Nganh - To hop mon" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Import" onAction="#onImport" styleClass="btn-success"/>
            <Button text="Them lien ket" onAction="#onAddNew" styleClass="btn-primary"/>
        </HBox>
        <TableView fx:id="table" styleClass="table">
            <columns>
                <TableColumn fx:id="colMaNganh" text="Ma nganh"/>
                <TableColumn fx:id="colTenNganh" text="Ten nganh"/>
                <TableColumn fx:id="colMaToHop" text="Ma to hop"/>
                <TableColumn fx:id="colTenToHop" text="Ten to hop"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
