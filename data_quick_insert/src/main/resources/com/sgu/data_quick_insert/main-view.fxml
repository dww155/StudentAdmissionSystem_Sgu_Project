<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgu.data_quick_insert.controller.MainController">
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="10" left="12"/>
            </padding>

            <Label text="Data Quick Insert (Direct JDBC + Excel)" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <TabPane fx:id="profileTabPane" prefHeight="120"/>

            <GridPane hgap="8" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" prefWidth="150"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="100" prefWidth="110"/>
                    <ColumnConstraints minWidth="110" prefWidth="130"/>
                </columnConstraints>

                <Label text="Excel file (.xlsx):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="excelPathField" promptText="Select Excel file"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Button fx:id="browseButton" text="Browse" onAction="#onBrowseExcel"
                        GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <Button fx:id="previewButton" text="Preview" onAction="#onPreview"
                        GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Sheet (optional):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="sheetNameField" promptText="Leave blank for first sheet"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Batch size:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="batchSizeField" promptText="1000"
                           GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Template columns:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="templateColumnsField" editable="false" promptText="Columns required by selected tab"
                           GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
            </GridPane>

            <Separator/>

            <GridPane hgap="8" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" prefWidth="150"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="90" prefWidth="100"/>
                    <ColumnConstraints minWidth="160" prefWidth="180"/>
                    <ColumnConstraints minWidth="80" prefWidth="90"/>
                    <ColumnConstraints minWidth="130" prefWidth="150"/>
                    <ColumnConstraints minWidth="100" prefWidth="130"/>
                </columnConstraints>

                <Label text="JDBC URL:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="jdbcUrlField" promptText="jdbc:mysql://localhost:3306/xt_bangquydoi?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC"
                           GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="6"/>

                <Label text="Username:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" promptText="root"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <PasswordField fx:id="passwordField" promptText="root"
                               GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Table:" GridPane.rowIndex="1" GridPane.columnIndex="4"/>
                <TextField fx:id="tableNameField" editable="false" promptText="Auto from selected tab"
                           GridPane.rowIndex="1" GridPane.columnIndex="5"/>

                <Button fx:id="testConnectionButton" text="Test Connection" onAction="#onTestConnection"
                        GridPane.rowIndex="1" GridPane.columnIndex="6"/>
            </GridPane>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="insertButton" text="Import Selected Tab" onAction="#onInsert"
                        style="-fx-font-weight: bold;"/>
                <ProgressIndicator fx:id="busyIndicator" visible="false" managed="false"
                                   prefWidth="22" prefHeight="22"/>
                <Label fx:id="statusLabel" text="Ready"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.72">
            <VBox spacing="6">
                <padding>
                    <Insets top="10" right="12" bottom="12" left="12"/>
                </padding>
                <Label text="Preview (first 200 data rows)"/>
                <TableView fx:id="previewTable" VBox.vgrow="ALWAYS"/>
            </VBox>
            <VBox spacing="6">
                <padding>
                    <Insets top="10" right="12" bottom="12" left="0"/>
                </padding>
                <Label text="Execution Log"/>
                <TextArea fx:id="logArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
